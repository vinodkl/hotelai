# Copy this to .env and fill in your values
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Switch between Anthropic and local Ollama:
#   LLM_PROVIDER=anthropic   (default) — uses Anthropic API + ANTHROPIC_API_KEY
#   LLM_PROVIDER=ollama      — uses local Ollama at OLLAMA_BASE_URL
#
# For Ollama: run `ollama pull llama3.1` (or another tool-capable model) first.
# Models with function-calling support: llama3.1, mistral-nemo, qwen2.5, etc.
LLM_PROVIDER=anthropic
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:latest

# ChromaDB (runs locally, no setup needed)
CHROMA_URL=http://localhost:8000

# For real embeddings (text-embedding-3-small) + Phase 5 fine-tuning
# Without this, RAG falls back to 44-dim keyword vectors (simpleEmbed)
OPENAI_API_KEY=your_openai_api_key_here
