# Copy this to .env and fill in your values
PORT=3001

# ── LLM Gateway ───────────────────────────────────────────────────────────────
# HotelAI always sends requests to a local LLM gateway (OpenAI-compatible API).
# The gateway decides where to route them (Anthropic, Ollama, etc.).
#
# LLM_GATEWAY_URL  — base URL of the gateway
# LLM_GATEWAY_KEY  — API key if the gateway requires one (omit if not needed)
# LLM_MODEL        — model name as the gateway expects it
LLM_GATEWAY_URL=http://localhost:8080/v1
LLM_GATEWAY_KEY=not-required
LLM_MODEL=claude-sonnet-4-6

# ChromaDB (runs locally, no setup needed)
CHROMA_URL=http://localhost:8000

# For real embeddings (text-embedding-3-small) + Phase 5 fine-tuning
# Without this, RAG falls back to 44-dim keyword vectors (simpleEmbed)
OPENAI_API_KEY=your_openai_api_key_here
